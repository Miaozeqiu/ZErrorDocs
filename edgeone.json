{
  "buildCommand": "npm run build",
  "outputDirectory": "docs/.vitepress/dist",
  "redirects": [
    {
      "source": "/docs",
      "destination": "/introduction",
      "statusCode": 302
    },
    {
      "source": "/docs/*",
      "destination": "/:splat",
      "statusCode": 302
    }
  ]
}
